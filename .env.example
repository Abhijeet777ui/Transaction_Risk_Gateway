# Gemini API Key (free tier — get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (optional, paid — only needed if PROVIDER=openai)
OPENAI_API_KEY=your-openai-key-here

# Gateway API Key (sent as X-API-Key header)
GATEWAY_API_KEY=change-me-in-production

# PostgreSQL Connection
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/gateway

# Optional: set to "true" to echo all SQL queries to console (debug only)
SQL_ECHO=false
